#!/usr/bin/env bash
# cc-test — test all cc modes: provider switches, model tiers, status, help
# Does NOT connect to any API — tests only local state (env.sh, active-backend, settings.json)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CC="${SCRIPT_DIR}/cc"
ACTIVE_FILE="${HOME}/.config/claude-code/active-backend"
ENV_FILE="${HOME}/.config/claude-code/env.sh"
SETTINGS="${HOME}/.claude/settings.json"

PASS=0; FAIL=0

# ── Helpers ───────────────────────────────────────────────────────────────────

ok()   { echo "  PASS  $1"; ((PASS++)); }
fail() { echo "  FAIL  $1"; ((FAIL++)); }

check() {
  local desc="$1" expected="$2" actual="$3"
  if [[ "$actual" == *"$expected"* ]]; then ok "$desc"; else fail "$desc  (expected: '$expected', got: '$actual')"; fi
}

check_empty() {
  local desc="$1" actual="$2"
  if [[ -z "$actual" ]]; then ok "$desc"; else fail "$desc  (expected empty, got: '$actual')"; fi
}

active()  { cat "$ACTIVE_FILE" 2>/dev/null; }
model()   { python3 -c "import json; print(json.load(open('${SETTINGS}'))['model'])" 2>/dev/null; }
envgrep() { grep -s "$1" "$ENV_FILE"; }

# Snapshot current state so we can restore it after the tests
ORIGINAL_ACTIVE=$(active)
ORIGINAL_MODEL=$(model)

# ── Tests ─────────────────────────────────────────────────────────────────────

echo ""
echo "cc-test — running all mode tests"
echo "────────────────────────────────────────────────────"

# -- cc teams -----------------------------------------------------------------
echo ""
echo "[ cc teams ]"
"$CC" teams >/dev/null
check "active-backend = teams"           "teams"                          "$(active)"
check "env.sh: unsets ANTHROPIC_API_KEY" "unset ANTHROPIC_API_KEY"        "$(envgrep 'unset ANTHROPIC_API_KEY')"
check_empty "env.sh: no BEDROCK export"  "$(envgrep 'CLAUDE_CODE_USE_BEDROCK=1')"
check_empty "env.sh: no VERTEX export"   "$(envgrep 'CLAUDE_CODE_USE_VERTEX=1')"
check "settings.json: opus model"        "opus"                           "$(model)"

# -- cc bedrock ---------------------------------------------------------------
echo ""
echo "[ cc bedrock ]"
"$CC" bedrock >/dev/null
check "active-backend = bedrock"         "bedrock"                       "$(active)"
check "env.sh: CLAUDE_CODE_USE_BEDROCK"  "CLAUDE_CODE_USE_BEDROCK=1"     "$(envgrep CLAUDE_CODE_USE_BEDROCK)"
check "env.sh: AWS_REGION"               "AWS_REGION=us-west-1"          "$(envgrep AWS_REGION)"
check "env.sh: unset line present"       "unset CLAUDE_CODE_USE_BEDROCK CLAUDE_CODE_USE_VERTEX"  "$(envgrep unset)"
check "settings.json: opus model"        "opus"                          "$(model)"

# -- cc vertex ----------------------------------------------------------------
echo ""
echo "[ cc vertex ]"
"$CC" vertex >/dev/null
check "active-backend = vertex"          "vertex"                        "$(active)"
check "env.sh: CLAUDE_CODE_USE_VERTEX"   "CLAUDE_CODE_USE_VERTEX=1"      "$(envgrep CLAUDE_CODE_USE_VERTEX)"
check "env.sh: CLOUD_ML_REGION"          "CLOUD_ML_REGION=us-east5"      "$(envgrep CLOUD_ML_REGION)"
check "settings.json: opus model"        "opus"                          "$(model)"

# -- cc foundry ---------------------------------------------------------------
echo ""
echo "[ cc foundry ]"
"$CC" foundry >/dev/null
check "active-backend = foundry"         "foundry"                       "$(active)"
check "env.sh: ANTHROPIC_BASE_URL"       "ANTHROPIC_BASE_URL"            "$(envgrep ANTHROPIC_BASE_URL)"
check "settings.json: opus model"        "opus"                          "$(model)"

# -- cc direct ----------------------------------------------------------------
echo ""
echo "[ cc direct ]"
"$CC" direct >/dev/null
check "active-backend = direct"          "direct"                        "$(active)"
check_empty "env.sh: no BEDROCK export"  "$(envgrep 'CLAUDE_CODE_USE_BEDROCK=1')"
check_empty "env.sh: no VERTEX export"   "$(envgrep 'CLAUDE_CODE_USE_VERTEX=1')"
check "settings.json: opus model"        "opus"                          "$(model)"

# -- model tiers on direct ----------------------------------------------------
echo ""
echo "[ model tiers on direct ]"
"$CC" opus >/dev/null
check "opus"                            "opus"                           "$(model)"
check "active-backend unchanged"        "direct"                         "$(active)"
"$CC" opus45 >/dev/null
check "opus45"                          "opus-4-5"                       "$(model)"
"$CC" sonnet >/dev/null
check "sonnet"                          "sonnet"                         "$(model)"
"$CC" sonnet45 >/dev/null
check "sonnet45"                        "sonnet-4-5"                     "$(model)"
"$CC" haiku >/dev/null
check "haiku"                           "haiku"                          "$(model)"
check "active-backend still direct"     "direct"                         "$(active)"

# -- model IDs on bedrock (cross-check) ---------------------------------------
echo ""
echo "[ model IDs on bedrock ]"
"$CC" bedrock >/dev/null
check "bedrock opus"                    "us.anthropic.claude-opus-4-6"   "$(model)"
"$CC" opus45  >/dev/null
check "bedrock opus45"                  "us.anthropic.claude-opus-4-5"   "$(model)"
"$CC" sonnet  >/dev/null
check "bedrock sonnet"                  "us.anthropic.claude-sonnet-4-6" "$(model)"
"$CC" sonnet45 >/dev/null
check "bedrock sonnet45"                "us.anthropic.claude-sonnet-4-5" "$(model)"
"$CC" haiku >/dev/null
check "bedrock haiku"                   "us.anthropic.claude-haiku"      "$(model)"

# -- model tiers on teams -----------------------------------------------------
echo ""
echo "[ model tiers on teams ]"
"$CC" teams >/dev/null
"$CC" opus45 >/dev/null
check "teams opus45"                    "claude-opus-4-5"                "$(model)"
check "active-backend = teams"          "teams"                          "$(active)"
"$CC" sonnet >/dev/null
check "teams sonnet"                    "claude-sonnet-4-6"              "$(model)"
"$CC" haiku >/dev/null
check "teams haiku"                     "claude-haiku-4-5"               "$(model)"
"$CC" opus >/dev/null
check "teams opus"                      "claude-opus-4-6"                "$(model)"

# -- cc status ----------------------------------------------------------------
echo ""
echo "[ cc status ]"
STATUS_OUT=$("$CC" status 2>&1)
EXIT=$?
[[ $EXIT -eq 0 ]] && ok "exit 0" || fail "exit $EXIT"
check "shows Provider"  "Provider"  "$STATUS_OUT"
check "shows Model"     "Model"     "$STATUS_OUT"

# -- cc help ------------------------------------------------------------------
echo ""
echo "[ cc help ]"
HELP_OUT=$("$CC" help 2>&1)
EXIT=$?
[[ $EXIT -eq 0 ]] && ok "exit 0" || fail "exit $EXIT"
check "shows PROVIDERS"         "PROVIDERS"         "$HELP_OUT"
check "shows MODEL TIER"        "MODEL TIER"        "$HELP_OUT"
check "shows RATE LIMIT"        "RATE LIMIT"        "$HELP_OUT"
check "shows teams"             "cc teams"          "$HELP_OUT"
check "shows cc check"          "cc check"          "$HELP_OUT"

# -- cc check -----------------------------------------------------------------
echo ""
echo "[ cc check ]"
CHECK_OUT=$("$CC" check 2>&1)
EXIT=$?
[[ $EXIT -eq 0 ]] && ok "exit 0" || fail "exit $EXIT"
check "shows teams"    "teams"    "$CHECK_OUT"
check "shows bedrock"  "bedrock"  "$CHECK_OUT"
check "shows vertex"   "vertex"   "$CHECK_OUT"

# -- cc scan (offline checks) ------------------------------------------------
echo ""
echo "[ cc scan ]"
[[ -x "${SCRIPT_DIR}/cc-scan" ]] && ok "cc-scan is executable" || fail "cc-scan not executable"
HELP_OUT=$("$CC" help 2>&1)
check "help mentions cc scan"  "cc scan"  "$HELP_OUT"

# -- cc <unknown> -------------------------------------------------------------
echo ""
echo "[ cc unknown ]"
"$CC" __no_such_cmd__ 2>/dev/null
[[ $? -ne 0 ]] && ok "exits non-zero on unknown cmd" || fail "should exit non-zero"

# ── Restore original state ───────────────────────────────────────────────────

echo ""
echo "[ restore ]"
if [[ -n "$ORIGINAL_ACTIVE" ]]; then
  "$CC" "$ORIGINAL_ACTIVE" >/dev/null
  # restore original model tier
  case "$ORIGINAL_MODEL" in
    *opus-4-5*)   "$CC" opus45   >/dev/null ;;
    *sonnet-4-5*) "$CC" sonnet45 >/dev/null ;;
    *sonnet*)     "$CC" sonnet   >/dev/null ;;
    *haiku*)      "$CC" haiku    >/dev/null ;;
    *)            "$CC" opus     >/dev/null ;;
  esac
  ok "restored to ${ORIGINAL_ACTIVE} / ${ORIGINAL_MODEL}"
else
  ok "nothing to restore"
fi

# ── Summary ──────────────────────────────────────────────────────────────────

TOTAL=$((PASS + FAIL))
echo ""
echo "────────────────────────────────────────────────────"
echo "  ${PASS}/${TOTAL} passed   ${FAIL} failed"
echo ""
[[ $FAIL -eq 0 ]] && exit 0 || exit 1
