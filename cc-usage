#!/usr/bin/python3
"""cc-usage: Check usage/status across multiple Claude Teams accounts.

Discovers accounts from:
  1. ~/.config/claude-code/accounts/*/   (standalone)
  2. ~/.ccs/instances/*/                  (ccs profiles)
  3. ~/.claude/                           (default, always included)

Probes three API endpoints per account:
  - GET /api/oauth/usage              → rate limit windows (5h, 7d, per-model)
  - GET /api/oauth/profile            → org name, billing, subscription status
  - GET /api/oauth/organizations/{id}/overage_credit_grant → credit balance

Usage:
  cc-usage              # Quick check (metadata only, no API calls)
  cc-usage --probe      # Full API probe (usage + profile + credits)
  cc-usage --json       # JSON output for scripting
"""

import json
import os
import sys
import time
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime, timezone
from pathlib import Path

HOME = Path.home()
CONFIG_DIR = HOME / ".config" / "claude-code"
ACCOUNTS_DIR = CONFIG_DIR / "accounts"

API_BASE = "https://api.anthropic.com"
AUTH_HEADERS = {"anthropic-beta": "oauth-2025-04-20", "Content-Type": "application/json"}

try:
    import httpx
    HAS_HTTPX = True
except ImportError:
    HAS_HTTPX = False


# ── Account discovery ────────────────────────────────────────────────────────

def find_accounts():
    """Find all account config directories."""
    accounts = {}

    # Default ~/.claude/
    default = HOME / ".claude"
    if (default / ".credentials.json").exists():
        accounts["default"] = default

    # Standalone accounts
    if ACCOUNTS_DIR.is_dir():
        for d in sorted(ACCOUNTS_DIR.iterdir()):
            if d.is_dir() and (d / ".credentials.json").exists():
                accounts[d.name] = d

    # CCS profiles
    ccs_dir = HOME / ".ccs" / "instances"
    if ccs_dir.is_dir():
        for d in sorted(ccs_dir.iterdir()):
            if d.is_dir() and (d / ".credentials.json").exists():
                accounts[f"ccs:{d.name}"] = d

    return accounts


# ── Credential reading ───────────────────────────────────────────────────────

def read_creds(config_dir):
    """Read metadata from .credentials.json."""
    creds_file = config_dir / ".credentials.json"
    try:
        data = json.loads(creds_file.read_text())
    except Exception as e:
        return {"error": str(e)}

    oauth = data.get("claudeAiOauth", {})
    expires_at = oauth.get("expiresAt", 0)
    now_ms = int(time.time() * 1000)
    expires_h = (expires_at - now_ms) / 3_600_000

    return {
        "subscription": oauth.get("subscriptionType", "?"),
        "rate_tier": oauth.get("rateLimitTier", "?"),
        "token_expires_h": round(expires_h, 1),
        "token_valid": expires_h > 0,
        "has_token": bool(oauth.get("accessToken")),
    }


def _get_token(config_dir):
    """Extract OAuth token and subscription type."""
    try:
        data = json.loads((config_dir / ".credentials.json").read_text())
        oauth = data.get("claudeAiOauth", {})
        return oauth.get("accessToken", ""), oauth.get("subscriptionType", "")
    except Exception:
        return "", ""


def _auth_headers(token):
    return {**AUTH_HEADERS, "Authorization": f"Bearer {token}"}


# ── API probes ───────────────────────────────────────────────────────────────

def _probe_usage(token):
    """GET /api/oauth/usage → rate limit windows + overage."""
    try:
        resp = httpx.get(f"{API_BASE}/api/oauth/usage",
                         headers=_auth_headers(token), timeout=10)

        # Extract retry-after from ANY response
        retry = resp.headers.get("retry-after")

        if resp.status_code == 429:
            result = {"probe": "rate_limited"}
            if retry:
                result["retry_after"] = retry
            return result

        if resp.status_code != 200:
            return {}

        data = resp.json()
        if not data:
            return {}

        result = {"probe": "ok"}

        # All rate limit windows
        for key in ("five_hour", "seven_day", "seven_day_opus", "seven_day_sonnet",
                     "seven_day_oauth_apps", "seven_day_cowork"):
            window = data.get(key)
            if window and isinstance(window, dict):
                util = window.get("utilization")
                if util is not None:
                    result[f"{key}_util"] = util
                resets = window.get("resets_at")
                if resets:
                    result[f"{key}_resets"] = resets

        # Extra usage / overage
        extra = data.get("extra_usage")
        if extra and isinstance(extra, dict):
            result["extra_enabled"] = extra.get("is_enabled", False)
            result["extra_monthly_limit"] = extra.get("monthly_limit")
            result["extra_used"] = extra.get("used_credits")
            result["extra_util"] = extra.get("utilization")

        return result

    except Exception:
        return {}


def _probe_profile(token):
    """GET /api/oauth/profile → account + org info."""
    try:
        resp = httpx.get(f"{API_BASE}/api/oauth/profile",
                         headers=_auth_headers(token), timeout=10)
        if resp.status_code != 200:
            return {}

        data = resp.json()
        result = {}

        acct = data.get("account", {})
        if acct:
            result["account_name"] = acct.get("display_name") or acct.get("full_name", "")
            result["account_email"] = acct.get("email", "")
            result["account_uuid"] = acct.get("uuid", "")

        org = data.get("organization", {})
        if org:
            result["org_name"] = org.get("name", "")
            result["org_uuid"] = org.get("uuid", "")
            result["org_type"] = org.get("organization_type", "")
            result["org_billing"] = org.get("billing_type", "")
            result["org_status"] = org.get("subscription_status", "")
            result["org_extra_usage"] = org.get("has_extra_usage_enabled", False)
            result["org_created"] = org.get("subscription_created_at", "")

        return result

    except Exception:
        return {}


def _probe_overage_grant(token, org_uuid):
    """GET /api/oauth/organizations/{id}/overage_credit_grant → credit balance."""
    if not org_uuid:
        return {}
    try:
        resp = httpx.get(
            f"{API_BASE}/api/oauth/organizations/{org_uuid}/overage_credit_grant",
            headers=_auth_headers(token), timeout=10)
        if resp.status_code != 200:
            return {}

        data = resp.json()
        return {
            "grant_available": data.get("available", False),
            "grant_eligible": data.get("eligible", False),
            "grant_granted": data.get("granted", False),
            "grant_amount_cents": data.get("amount_minor_units"),
            "grant_currency": data.get("currency", "USD"),
        }

    except Exception:
        return {}


def check_sessions(config_dir):
    """Check for active Claude Code sessions."""
    sessions_dir = config_dir / "sessions"
    if not sessions_dir.is_dir():
        return {"sessions": 0}

    active = 0
    latest = None
    for f in sessions_dir.glob("*.json"):
        try:
            s = json.loads(f.read_text())
            pid = s.get("pid")
            if pid:
                try:
                    os.kill(pid, 0)
                    active += 1
                    started = s.get("startedAt", 0)
                    if started and (latest is None or started > latest):
                        latest = started
                except ProcessLookupError:
                    pass
        except Exception:
            pass

    result = {"sessions": active}
    if latest:
        elapsed_h = (time.time() * 1000 - latest) / 3_600_000
        result["latest_session_h"] = round(elapsed_h, 1)
    return result


def check_account(name, config_dir, do_probe=False):
    """Full check for one account."""
    info = {"name": name, "path": str(config_dir)}
    info.update(read_creds(config_dir))
    info.update(check_sessions(config_dir))

    if do_probe and info.get("token_valid"):
        token, sub_type = _get_token(config_dir)
        if token and sub_type in ("team", "max", "pro", "enterprise"):
            # Parallel API calls for this account
            usage = _probe_usage(token)
            profile = _probe_profile(token)
            info.update(usage)
            info.update(profile)

            # Overage grant needs org_uuid from profile
            org_uuid = info.get("org_uuid")
            if org_uuid and info.get("extra_enabled"):
                info.update(_probe_overage_grant(token, org_uuid))

    return info


# ── Formatting ───────────────────────────────────────────────────────────────

def _format_util(pct):
    """Format utilization percentage with visual bar."""
    if pct is None:
        return "—"
    pct = float(pct)
    if pct >= 95:
        return f"█ {pct:.0f}%"
    if pct >= 75:
        return f"▓ {pct:.0f}%"
    if pct >= 50:
        return f"▒ {pct:.0f}%"
    if pct >= 25:
        return f"░ {pct:.0f}%"
    return f"  {pct:.0f}%"


def _parse_reset(iso_str):
    """Parse ISO reset time to human-friendly duration from now."""
    if not iso_str:
        return None
    try:
        reset_time = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        delta = (reset_time - now).total_seconds()
        if delta <= 0:
            return "now"
        if delta > 86400:
            return f"{delta / 86400:.1f}d"
        if delta > 3600:
            return f"{delta / 3600:.1f}h"
        return f"{delta / 60:.0f}m"
    except Exception:
        return None


def fmt_status(info):
    if info.get("error"):
        return "✗ Error"
    if not info.get("has_token"):
        return "✗ No token"
    if not info.get("token_valid"):
        return "✗ Expired"
    probe = info.get("probe")
    if probe == "ok":
        return "✓ Ready"
    if probe == "rate_limited":
        return "~ Limited"
    if probe == "token_ok":
        return "✓ Token OK"
    if info.get("token_valid"):
        return "✓ Valid"
    return "?"


def fmt_org(info):
    return info.get("org_name", "—")


def fmt_5h(info):
    return _format_util(info.get("five_hour_util"))


def fmt_7d(info):
    return _format_util(info.get("seven_day_util"))


def fmt_sonnet(info):
    return _format_util(info.get("seven_day_sonnet_util"))


def fmt_overage(info):
    """Format overage: spent / grant, or just spent. Blank if deduped."""
    if info.get("extra_deduped"):
        return "↑"
    if not info.get("extra_enabled"):
        return "—"
    used = info.get("extra_used")
    if used is None:
        return "—"
    used_f = float(used) / 100  # API returns cents

    grant = info.get("grant_amount_cents")
    if grant and int(grant) > 0:
        grant_f = int(grant) / 100
        return f"${used_f:.0f}/${grant_f:.0f}"
    if used_f > 0:
        return f"${used_f:.2f}"
    return "$0"


def fmt_remaining(info):
    """Format remaining overage credits. Blank if deduped."""
    if info.get("extra_deduped"):
        return "↑"
    grant = info.get("grant_amount_cents")
    used = info.get("extra_used")
    if grant and used is not None:
        remaining = (int(grant) - float(used)) / 100
        if remaining <= 0:
            return "✗ $0"
        return f"${remaining:.0f}"
    return "—"


def fmt_reset(info):
    """Format nearest rate limit reset."""
    for key in ("five_hour_resets", "seven_day_resets", "seven_day_opus_resets",
                "seven_day_sonnet_resets"):
        val = _parse_reset(info.get(key))
        if val:
            return val
    for retry_key in ("retry_after", "retry-after"):
        retry = info.get(retry_key)
        if retry:
            try:
                s = int(retry)
                if s >= 3600:
                    return f"{s / 3600:.1f}h"
                return f"{s // 60}m{s % 60}s" if s >= 60 else f"{s}s"
            except ValueError:
                pass
    return "—"


# ── Table rendering ──────────────────────────────────────────────────────────

def _dedup_org_overage(results):
    """Overage grant is org-level, not per-seat. Keep it only on the first account per org."""
    seen_orgs = set()
    for r in results:
        org = r.get("org_uuid")
        if not org:
            continue
        if org in seen_orgs:
            # Clear per-seat overage display — already shown on first account for this org
            r.pop("grant_amount_cents", None)
            r.pop("extra_used", None)
            r["extra_deduped"] = True
        else:
            seen_orgs.add(org)


def render_table(results, do_probe):
    """Print results as a formatted table."""
    has_usage = do_probe and any(r.get("five_hour_util") is not None for r in results)
    has_org = any(r.get("org_name") for r in results)
    has_sonnet = any(r.get("seven_day_sonnet_util") is not None for r in results)
    has_grant = any(r.get("grant_amount_cents") for r in results)

    if has_usage:
        cols = [
            ("Account", 12, lambda r: r["name"]),
            ("Status", 11, lambda r: fmt_status(r)),
        ]
        if has_org:
            cols.append(("Org", 14, lambda r: fmt_org(r)))
        cols += [
            ("5h", 7, lambda r: fmt_5h(r)),
            ("7d", 7, lambda r: fmt_7d(r)),
        ]
        if has_sonnet:
            cols.append(("Son 7d", 7, lambda r: fmt_sonnet(r)))
        cols.append(("Overage", 9, lambda r: fmt_overage(r)))
        if has_grant:
            cols.append(("Left", 6, lambda r: fmt_remaining(r)))
        cols += [
            ("Reset", 6, lambda r: fmt_reset(r)),
            ("Ses", 3, lambda r: str(r.get("sessions", 0))),
        ]
    elif do_probe:
        cols = [
            ("Account", 14, lambda r: r["name"]),
            ("Status", 12, lambda r: fmt_status(r)),
            ("Sessions", 8, lambda r: str(r.get("sessions", 0))),
            ("Reset", 8, lambda r: fmt_reset(r)),
        ]
    else:
        cols = [
            ("Account", 14, lambda r: r["name"]),
            ("Status", 12, lambda r: fmt_status(r)),
            ("Tier", 10, lambda r: r.get("rate_tier", "?").replace("default_claude_", "").replace("default_", "")),
            ("Sessions", 8, lambda r: str(r.get("sessions", 0))),
        ]

    # Draw table
    print()
    hr = lambda ch: "  " + ch[0] + ch[1].join(f"─{'─' * w}─" for _, w, _ in cols) + ch[2]
    print(hr("┌┬┐"))
    print("  │" + "│".join(f" {name:<{w}} " for name, w, _ in cols) + "│")
    print(hr("├┼┤"))
    for r in results:
        print("  │" + "│".join(f" {fn(r):<{w}} " for _, w, fn in cols) + "│")
    print(hr("└┴┘"))
    print()


def render_summary(results):
    """Print summary below the table."""
    # Best account recommendation (lowest 7d utilization — more strategic than 5h)
    with_7d = [r for r in results if r.get("seven_day_util") is not None and r.get("token_valid")]
    if with_7d:
        best = min(with_7d, key=lambda r: r.get("seven_day_util", 100))
        worst = max(with_7d, key=lambda r: r.get("seven_day_util", 0))

        if worst.get("seven_day_util", 0) >= 50 and best["name"] != worst["name"]:
            print(f"  Best: cc account {best['name']}  (7d: {best.get('seven_day_util', 0):.0f}%)")

    # Total overage across all orgs
    orgs_seen = set()
    total_used = 0
    total_grant = 0
    for r in results:
        org = r.get("org_uuid", r["name"])
        if org in orgs_seen:
            continue
        orgs_seen.add(org)
        used = r.get("extra_used")
        if used is not None:
            total_used += float(used) / 100
        grant = r.get("grant_amount_cents")
        if grant:
            total_grant += int(grant) / 100

    if total_used > 0 or total_grant > 0:
        remaining = total_grant - total_used
        parts = [f"Overage: ${total_used:.2f} used"]
        if total_grant > 0:
            parts.append(f"${remaining:.2f} remaining of ${total_grant:.0f} grant")
        print(f"  {' / '.join(parts)}")

    # Rate-limited accounts
    limited = [r for r in results if r.get("probe") == "rate_limited"]
    if limited:
        names = ", ".join(r["name"] for r in limited)
        print(f"  Rate-limited: {names}")

    print()


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    do_probe = "--probe" in sys.argv
    do_json = "--json" in sys.argv

    if do_probe and not HAS_HTTPX:
        print("  ✗ --probe requires httpx: pip install httpx", file=sys.stderr)
        sys.exit(1)

    accounts = find_accounts()
    if not accounts:
        print("  No accounts found.")
        print("  Set up accounts with: cc setup-accounts")
        sys.exit(1)

    # Check all accounts in parallel
    results = []
    with ThreadPoolExecutor(max_workers=8) as pool:
        futures = {
            pool.submit(check_account, name, path, do_probe): name
            for name, path in accounts.items()
        }
        for f in as_completed(futures):
            results.append(f.result())

    # Sort: accounts with overage data first (so dedup keeps the richest), then alphabetical
    results.sort(key=lambda r: (
        0 if r.get("extra_used") and float(r.get("extra_used", 0)) > 0 else 1,
        "" if r["name"] == "default" else r["name"],
    ))

    # Overage grant is org-level — only show it once per org
    _dedup_org_overage(results)

    if do_json:
        # Include everything for scripting
        # Strip raw token data for safety
        safe = []
        for r in results:
            s = {k: v for k, v in r.items() if k != "usage_raw"}
            safe.append(s)
        print(json.dumps(safe, indent=2))
    else:
        render_table(results, do_probe)

        if do_probe:
            render_summary(results)
        else:
            print("  Tip: cc usage --probe  (full API check: usage, org, credits)")
            print()


if __name__ == "__main__":
    main()
