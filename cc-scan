                    cell_text = f"✗ {label[:6]:<6}"
                    cell = f" {color}✗ {label[:6]:<6}{RESET}"
            else:
                cell_text = "  ??   "
                cell = f" {GRAY}  ??   {RESET}"
            # Pad: col_w minus visible chars, then add the ANSI cell
            pad = col_w - len(cell_text)
            row += " " * max(0, pad) + cell
        print(row)

    # Bottom separator
    print(f"  {DIM}{'─' * (label_w + (col_w + 1) * len(PROVIDERS))}{RESET}")

    # Summary
    summary_parts = []
    if n_pass: summary_parts.append(f"{GREEN}{n_pass} pass{RESET}")
    if n_fail: summary_parts.append(f"{RED}{n_fail} fail{RESET}")
    if n_rate: summary_parts.append(f"{YELLOW}{n_rate} limited{RESET}")
    if n_skip: summary_parts.append(f"{GRAY}{n_skip} skip{RESET}")

    print(f"  {DIM}{len(PROVIDERS)} providers × {len(TIERS)} models = {n_total} checks{RESET}  │  {' · '.join(summary_parts)}")
    print(f"  {DIM}Wall time: {wall_time:.1f}s (parallel){RESET}")

    # Best provider recommendation
    provider_scores = {}
    for p in PROVIDERS:
        passes = sum(1 for t in TIERS if results.get((p, t), ("",))[0] == "pass")
        avg_ms = 0
        ms_count = 0
        for t in TIERS:
            r = results.get((p, t))
            if r and r[0] == "pass" and r[3] > 0:
                avg_ms += r[3]
                ms_count += 1
        avg_ms = avg_ms // ms_count if ms_count else 99999
        provider_scores[p] = (passes, -avg_ms)

    best = max((p for p in PROVIDERS if p != "teams"), key=lambda p: provider_scores[p])
    bp = provider_scores[best]
    if bp[0] > 0:
        print(f"  {CYAN}Best provider: {BOLD}{best}{RESET}{CYAN} ({bp[0]}/{len(TIERS)} models, avg {-bp[1]}ms){RESET}")

    # Hints for non-working providers
    hints = []
    vtx_err = creds["vertex"].get("_error", "")
    vtx_pass = any(results.get(("vertex", t), ("",))[0] == "pass" for t in TIERS)
    fnd_nodeploy = any(results.get(("foundry", t), ("",))[0] == "nodeploy" for t in TIERS)
    fnd_nocreds = not creds["foundry"]["api_key"]
    direct_nocreds = not creds["direct"]["api_key"]

    if vtx_err == "auth-expired":
        hints.append(f"{YELLOW}vertex{RESET}:  run {BOLD}gcloud auth login{RESET} to refresh expired token")
    elif vtx_err == "no-gcloud":
        hints.append(f"{YELLOW}vertex{RESET}:  install gcloud CLI → {DIM}https://cloud.google.com/sdk/docs/install{RESET}")
    elif not vtx_pass and not vtx_err:
        hints.append(f"{YELLOW}vertex{RESET}:  enable Claude via Anthropic publisher on Vertex AI")
    if fnd_nodeploy:
        hints.append(f"{YELLOW}foundry{RESET}: deploy Claude model in Azure AI Foundry → {DIM}https://ai.azure.com{RESET}")
    elif fnd_nocreds:
        hints.append(f"{YELLOW}foundry{RESET}: run {BOLD}cc setup-foundry{RESET} to configure Azure endpoint + key")
    if direct_nocreds:
        hints.append(f"{YELLOW}direct{RESET}:  run {BOLD}cc setup-direct{RESET} to add Anthropic API key")

    if hints:
        print()
        print(f"  {DIM}Hints:{RESET}")
        for h in hints:
            print(f"    {h}")

    print()


async def scan_extended(creds):
    """Scan all models including Azure serverless, Bedrock extras, and Google."""
    results = {}
    wall_start = time.perf_counter()

    async with httpx.AsyncClient() as client:
        tasks = []

        # Azure serverless models
        ep = creds["foundry"]["endpoint"]
        ak = creds["foundry"]["api_key"]
        if ep and ak:
            for model in AZURE_SERVERLESS:
                tasks.append(scan_single(client, "azure", model, creds, results))

        # Bedrock extra models
        bak = creds["bedrock"]["access_key"]
        bsk = creds["bedrock"]["secret_key"]
        if bak and bsk:
            for name, model_id in BEDROCK_EXTRA.items():
                tasks.append(scan_single(client, "bedrock-x", name, creds, results, model_id))

        # Google models
        gak = creds.get("google", {}).get("api_key", "")
        if gak:
            for model in GOOGLE_MODELS:
                tasks.append(scan_single(client, "google", model, creds, results))

        await asyncio.gather(*tasks)

    wall_time = time.perf_counter() - wall_start
    return results, wall_time


async def scan_single(client, provider, model, creds, results, model_id=None):
    """Test a single model."""
    key = (provider, model)
    model_id = model_id or model
    try:
        if provider == "azure":
            ep = creds["foundry"]["endpoint"]
            ak = creds["foundry"]["api_key"]
            code, ms, body = await test_azure_serverless(client, model_id, ep, ak)
        elif provider == "bedrock-x":
            ak = creds["bedrock"]["access_key"]
            sk = creds["bedrock"]["secret_key"]
            region = creds["bedrock"]["region"]
            code, ms, body = await test_bedrock_extra(client, model_id, ak, sk, region)
        elif provider == "google":
            gak = creds.get("google", {}).get("api_key", "")
            code, ms, body = await test_google(client, model_id, gak)
        else:
            results[key] = ("skip", GRAY, "--", 0, "unknown")
            return

        kind, color, label = classify(code, body)
        results[key] = (kind, color, label, ms, "")
    except httpx.TimeoutException:
        results[key] = ("error", RED, "timeout", 0, "")
    except Exception as e:
        results[key] = ("error", RED, "error", 0, str(e)[:40])


def render_extended(results, wall_time, creds):
    """Render extended model scan results."""
    print()
    print(f"  {BOLD}{CYAN}cc scan --all{RESET} {DIM}— Extended Model Availability{RESET}")
    print()

    # Group by provider
    providers = {"azure": [], "bedrock-x": [], "google": []}
    for (prov, model), res in sorted(results.items()):
        if prov in providers:
            providers[prov].append((model, res))

    for prov, models in providers.items():
        if not models:
            continue
        prov_name = {"azure": "Azure Serverless", "bedrock-x": "AWS Bedrock", "google": "Google Gemini"}[prov]
        print(f"  {BOLD}{prov_name}{RESET}")
        for model, (kind, color, label, ms, _) in models:
            if kind == "pass":
                status = f"{GREEN}✓{RESET} {DIM}{ms:>4}ms{RESET}"
            elif kind == "skip":
                status = f"{GRAY}--{RESET}"
            elif kind in ("rate", "quota"):
                status = f"{YELLOW}~ {label}{RESET}"
            else:
                status = f"{RED}✗ {label}{RESET}"
            print(f"    {model:<35} {status}")
        print()

    # Summary
    n_pass = sum(1 for v in results.values() if v[0] == "pass")
    n_fail = sum(1 for v in results.values() if v[0] in ("error", "auth", "missing"))
    n_total = len(results)
    print(f"  {DIM}{n_total} models tested | {GREEN}{n_pass} pass{RESET} | {DIM}Wall time: {wall_time:.1f}s{RESET}")
    print()


async def list_catalog(creds):
    """List all deployable models from provider catalogs."""
    print()
    print(f"  {BOLD}{CYAN}cc scan --catalog{RESET} {DIM}— Deployable Models{RESET}")
    print()

    # Bedrock foundation models
    ak = creds["bedrock"]["access_key"]
    sk = creds["bedrock"]["secret_key"]
    region = creds["bedrock"]["region"]
    if ak and sk:
        print(f"  {BOLD}AWS Bedrock{RESET} {DIM}(foundation models){RESET}")
        try:
            url = f"https://bedrock.{region}.amazonaws.com/foundation-models"
            body = ""
            headers = _aws_sign("GET", url, body, region, ak, sk)
            async with httpx.AsyncClient() as client:
                resp = await client.get(url, headers=headers, timeout=30.0)
                if resp.status_code == 200:
                    data = resp.json()
                    models = data.get("modelSummaries", [])
                    # Group by provider
                    by_provider = {}
                    for m in models:
                        prov = m.get("providerName", "Unknown")
                        name = m.get("modelId", "")
                        if prov not in by_provider:
                            by_provider[prov] = []
                        by_provider[prov].append(name)
                    for prov in sorted(by_provider.keys()):
                        print(f"    {CYAN}{prov}{RESET}: {len(by_provider[prov])} models")
                        for m in sorted(by_provider[prov])[:5]:
                            print(f"      {DIM}{m}{RESET}")
                        if len(by_provider[prov]) > 5:
                            print(f"      {DIM}... +{len(by_provider[prov])-5} more{RESET}")
                else:
                    print(f"    {RED}Error: {resp.status_code}{RESET}")
        except Exception as e:
            print(f"    {RED}Error: {e}{RESET}")
        print()

    # Azure - just show known serverless models
    if creds["foundry"]["api_key"]:
        print(f"  {BOLD}Azure AI Foundry{RESET} {DIM}(serverless){RESET}")
        for m in AZURE_SERVERLESS:
            print(f"    {DIM}{m}{RESET}")
        print()

    # Google
    gak = creds.get("google", {}).get("api_key", "")
    if gak:
        print(f"  {BOLD}Google Gemini{RESET}")
        for m in GOOGLE_MODELS:
            print(f"    {DIM}{m}{RESET}")
        print()


def main():
    # Parse args
    scan_all = "--all" in sys.argv
    show_catalog = "--catalog" in sys.argv

    if show_catalog:
        creds = load_credentials()
        asyncio.run(list_catalog(creds))
        sys.exit(0)

    # Run Claude scan (default)
    results, wall_time, creds = asyncio.run(run_scan())
    render_table(results, wall_time, creds)

    # If --all, also run extended scan
    if scan_all:
        ext_results, ext_time = asyncio.run(scan_extended(creds))
        render_extended(ext_results, ext_time, creds)

    # Exit code: 0 if any model passes, 1 if all fail
    if any(v[0] == "pass" for v in results.values()):
        sys.exit(0)
    sys.exit(1)


if __name__ == "__main__":
    main()
