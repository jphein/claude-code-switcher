# ── Result classification ────────────────────────────────────────────────────

def classify(status_code, body=""):
    """Classify API response into (symbol, color, label)."""
    body_lower = body.lower()
    if status_code == 200:
        return "pass", GREEN, "OK"
    if status_code == 429:
        return "rate", YELLOW, "rate-limited"
    if status_code in (401, 403):
        if "invalid subscription" in body_lower or "wrong api endpoint" in body_lower:
            return "nodeploy", YELLOW, "no-deploy"
        return "auth", RED, "auth-fail"
    if status_code == 404:
        if "not found" in body_lower or "not available" in body_lower:
            return "missing", RED, "not-avail"
        return "missing", RED, "not-found"
    if "quota" in body_lower or "resource_exhausted" in body_lower:
        return "quota", YELLOW, "no-quota"
    if "not enabled" in body_lower or "not available" in body_lower:
        return "missing", RED, "not-enabl"
    if status_code == 0:
        return "skip", GRAY, "no-creds"
    if 400 <= status_code < 500:
        return "error", RED, f"err-{status_code}"
    if status_code >= 500:
        return "error", RED, f"srv-{status_code}"
    return "error", RED, f"http-{status_code}"

# ── Main scan ────────────────────────────────────────────────────────────────

async def scan_provider(client, provider, creds, results):
    """Test all models for a single provider."""
    models = MODELS.get(provider, {})

    for tier in TIERS:
        model_id = models.get(tier, "")
        key = (provider, tier)

        if provider == "teams":
            results[key] = ("skip", GRAY, "--", 0, "OAuth")
            continue

        try:
            if provider == "direct":
                ak = creds["direct"]["api_key"]
                if not ak:
                    results[key] = ("skip", GRAY, "--", 0, "no key")
                    continue
                code, ms, body = await test_direct(client, model_id, ak)

            elif provider == "bedrock":
                ak = creds["bedrock"]["access_key"]
                sk = creds["bedrock"]["secret_key"]
                if not ak or not sk:
                    results[key] = ("skip", GRAY, "--", 0, "no creds")
                    continue
                code, ms, body = await test_bedrock(client, model_id, ak, sk, creds["bedrock"]["region"])

            elif provider == "vertex":
                tok = creds["vertex"].get("token", "")
                gak = creds["vertex"].get("api_key", "")
                vtx_err = creds["vertex"].get("_error", "")
                if not tok and not gak:
                    label = vtx_err or "no creds"
                    results[key] = ("skip", GRAY, label, 0, label)
                    continue
                code, ms, body = await test_vertex(client, model_id, creds["vertex"])

            elif provider == "foundry":
                ep = creds["foundry"]["endpoint"]
                ak = creds["foundry"]["api_key"]
                if not ep or not ak:
                    results[key] = ("skip", GRAY, "--", 0, "no creds")
                    continue
                code, ms, body = await test_foundry(client, model_id, ep, ak)

            else:
                results[key] = ("skip", GRAY, "--", 0, "unknown")
                continue

            kind, color, label = classify(code, body)
            results[key] = (kind, color, label, ms, "")

        except httpx.TimeoutException:
            results[key] = ("error", RED, "timeout", 0, "")
        except Exception as e:
            results[key] = ("error", RED, "error", 0, str(e)[:40])


async def run_scan():
    """Run the full scan across all providers and models."""
    creds = load_credentials()
    results = {}
    wall_start = time.perf_counter()

    async with httpx.AsyncClient() as client:
        tasks = [scan_provider(client, p, creds, results) for p in PROVIDERS]
        await asyncio.gather(*tasks)

    wall_time = time.perf_counter() - wall_start
    return results, wall_time, creds


def render_table(results, wall_time, creds):
    """Render the beautiful matrix table."""
    # Column widths
    label_w = 13
    col_w = 11

    # Count stats
    n_pass = sum(1 for v in results.values() if v[0] == "pass")
    n_fail = sum(1 for v in results.values() if v[0] in ("error", "auth", "missing"))
    n_rate = sum(1 for v in results.values() if v[0] in ("rate", "quota"))
    n_skip = sum(1 for v in results.values() if v[0] in ("skip", "nodeploy"))
    n_total = len(results)

    # Header
    print()
    print(f"  {BOLD}{CYAN}cc scan{RESET} {DIM}— Claude Model Availability Matrix{RESET}")
    print()

    # Credential summary
    cred_indicators = []
    for p in PROVIDERS:
        if p == "teams":
            cred_indicators.append(f"{GRAY}OAuth{RESET}")
        elif p == "direct":
            cred_indicators.append(f"{GREEN}key{RESET}" if creds["direct"]["api_key"] else f"{RED}--{RESET}")
        elif p == "bedrock":
            cred_indicators.append(f"{GREEN}aws{RESET}" if creds["bedrock"]["access_key"] else f"{RED}--{RESET}")
        elif p == "vertex":
            tok = creds["vertex"].get("token", "")
            vtx_err = creds["vertex"].get("_error", "")
            if tok:
                cred_indicators.append(f"{GREEN}token{RESET}")
            elif vtx_err == "auth-expired":
                cred_indicators.append(f"{YELLOW}expired{RESET}")
            elif vtx_err == "no-gcloud":
                cred_indicators.append(f"{RED}no-cli{RESET}")
            else:
                cred_indicators.append(f"{RED}--{RESET}")
        elif p == "foundry":
            cred_indicators.append(f"{GREEN}key{RESET}" if creds["foundry"]["api_key"] else f"{RED}--{RESET}")

    # Table top
    sep = f"{'':>{label_w}} "
    for i, p in enumerate(PROVIDERS):
        sep += f"  {cred_indicators[i]:>18}"
    print(f"  {DIM}Credentials:{RESET}{sep}")
    print()

    # Provider header row
    header = f"  {HEADER_BG}{BOLD}{'':>{label_w}}{RESET}"
    for p in PROVIDERS:
        header += f" {HEADER_BG}{BOLD}{p:^{col_w}}{RESET}"
    print(header)

    # Separator
    line = f"  {'':─>{label_w}}"
    for _ in PROVIDERS:
        line += f"─{'':─>{col_w}}"
    print(f"  {DIM}{'─' * (label_w + (col_w + 1) * len(PROVIDERS))}{RESET}")

    # Model rows
    for tier in TIERS:
        row = f"  {WHITE}{tier:>{label_w}}{RESET}"
        for provider in PROVIDERS:
            key = (provider, tier)
            if key in results:
                kind, color, label, ms, extra = results[key]
                if kind == "pass":
                    cell_text = f"✓ {ms:>4}ms"
                    cell = f" {color}✓{RESET} {DIM}{ms:>4}ms{RESET}"
                elif kind == "skip":
                    if label and label not in ("--", "no creds", "OAuth"):
                        short = label[:7]
                        cell_text = f"{short:^8}"
                        cell = f" {YELLOW}{short:^8}{RESET}"
                    else:
                        cell_text = "  --   "
                        cell = f" {GRAY}  --   {RESET}"
                elif kind == "nodeploy":
                    cell_text = "no-dply"
                    cell = f" {YELLOW}no-dply{RESET}"
