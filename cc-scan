# ── Credential loading ───────────────────────────────────────────────────────

def _load_env_file(path):
    """Parse a shell env file for export KEY=VALUE lines."""
    vals = {}
    if not os.path.exists(path):
        return vals
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line.startswith("#") or "=" not in line:
                continue
            line = line.removeprefix("export ")
            key, _, val = line.partition("=")
            vals[key.strip()] = val.strip().strip('"').strip("'")
    return vals


def _load_aws_creds():
    """Load AWS credentials from ~/.aws/credentials."""
    cp = ConfigParser()
    cp.read(os.path.expanduser("~/.aws/credentials"))
    if cp.has_section("default"):
        return cp.get("default", "aws_access_key_id", fallback=""), cp.get("default", "aws_secret_access_key", fallback="")
    return "", ""


def _load_chat_assistant_config():
    """Load the chat assistant config as fallback credentials."""
    path = os.path.expanduser("~/.config/azure-chat-assistant/config.json")
    if os.path.exists(path):
        with open(path) as f:
            return json.load(f)
    return {}


def load_credentials():
    """Load all available credentials from various sources."""
    creds = {
        "direct": {"api_key": ""},
        "bedrock": {"access_key": "", "secret_key": "", "region": "us-west-1"},
        "vertex": {"token": "", "project": "", "region": "us-east5"},
        "foundry": {"endpoint": "", "api_key": ""},
        "teams": {"available": False},
        "google": {"api_key": ""},
    }

    # Direct: from env file or environment
    direct_env = _load_env_file(os.path.expanduser("~/.config/claude-code/direct.env"))
    creds["direct"]["api_key"] = direct_env.get("ANTHROPIC_API_KEY", os.environ.get("ANTHROPIC_API_KEY", ""))

    # Bedrock: from ~/.aws/credentials
    ak, sk = _load_aws_creds()
    if ak and sk:
        creds["bedrock"]["access_key"] = ak
        creds["bedrock"]["secret_key"] = sk

    # Vertex: try gcloud for token
    import shutil
    gcloud = shutil.which("gcloud") or os.path.expanduser("~/google-cloud-sdk/bin/gcloud")
    if os.path.exists(gcloud):
        try:
            token = subprocess.check_output([gcloud, "auth", "print-access-token"], timeout=10, stderr=subprocess.PIPE).decode().strip()
            project = subprocess.check_output([gcloud, "config", "get-value", "project"], timeout=5, stderr=subprocess.DEVNULL).decode().strip()
            creds["vertex"]["token"] = token
            creds["vertex"]["project"] = project
        except subprocess.CalledProcessError:
            creds["vertex"]["_error"] = "auth-expired"
        except Exception:
            creds["vertex"]["_error"] = "gcloud-error"
    else:
        creds["vertex"]["_error"] = "no-gcloud"

    # Foundry: from env file
    foundry_env = _load_env_file(os.path.expanduser("~/.config/claude-code/foundry.env"))
    creds["foundry"]["endpoint"] = foundry_env.get("AZURE_FOUNDRY_ENDPOINT", "")
    creds["foundry"]["api_key"] = foundry_env.get("AZURE_ANTHROPIC_API_KEY", "")

    # Fallback: chat assistant config
    ca = _load_chat_assistant_config()
    if ca:
        if not creds["bedrock"]["access_key"] and ca.get("aws_access_key"):
            creds["bedrock"]["access_key"] = ca["aws_access_key"]
            creds["bedrock"]["secret_key"] = ca.get("aws_secret_key", "")
            creds["bedrock"]["region"] = ca.get("aws_region", "us-west-1")
        if not creds["foundry"]["endpoint"] and ca.get("endpoint"):
            ep = ca["endpoint"].rstrip("/")
            creds["foundry"]["endpoint"] = ep
            creds["foundry"]["api_key"] = ca.get("api_key", "")
        # Note: Google API key from chat assistant is for Gemini, not Claude on Vertex.
        # Claude on Vertex requires gcloud OAuth token + anthropic publisher endpoint.
        if ca.get("google_api_key"):
            creds["google"]["api_key"] = ca["google_api_key"]

    return creds

# ── AWS SigV4 signing ────────────────────────────────────────────────────────

def _aws_sign(method, url, payload, region, access_key, secret_key):
    """Sign an AWS request using SigV4. Returns headers dict."""
    parsed = urlparse(url)
    host = parsed.netloc
    uri = parsed.path or "/"
    t = datetime.now(timezone.utc)
    amz_date = t.strftime("%Y%m%dT%H%M%SZ")
    date_stamp = t.strftime("%Y%m%d")

    canonical_uri = quote(uri, safe="/-_.~")
    headers_to_sign = {"host": host, "x-amz-date": amz_date, "content-type": "application/json"}
    signed_headers = ";".join(sorted(headers_to_sign.keys()))
    canonical_headers = "".join(f"{k}:{v}\n" for k, v in sorted(headers_to_sign.items()))
    payload_hash = hashlib.sha256(payload.encode()).hexdigest()

    canonical_request = f"{method}\n{canonical_uri}\n\n{canonical_headers}\n{signed_headers}\n{payload_hash}"
    algorithm = "AWS4-HMAC-SHA256"
    credential_scope = f"{date_stamp}/{region}/bedrock/aws4_request"
    string_to_sign = f"{algorithm}\n{amz_date}\n{credential_scope}\n{hashlib.sha256(canonical_request.encode()).hexdigest()}"

    def sign(key, msg):
        return hmac.new(key, msg.encode(), hashlib.sha256).digest()

    k_date = sign(f"AWS4{secret_key}".encode(), date_stamp)
    k_region = sign(k_date, region)
    k_service = sign(k_region, "bedrock")
    k_signing = sign(k_service, "aws4_request")
    signature = hmac.new(k_signing, string_to_sign.encode(), hashlib.sha256).hexdigest()

    authorization = f"{algorithm} Credential={access_key}/{credential_scope}, SignedHeaders={signed_headers}, Signature={signature}"
    return {"host": host, "x-amz-date": amz_date, "content-type": "application/json", "authorization": authorization}

